# ── Server-side secrets (set these in Vercel Dashboard → Settings → Environment Variables)
# These are NOT prefixed with VITE_ — they must stay server-side only.

# BallDontLie API key — gates player search (/api/bdl proxy)
# Sign up: https://www.balldontlie.io
BDL_API_KEY=your_balldontlie_key

# The Odds API key — gates betting edge finder (/api/odds proxy)
# Sign up: https://the-odds-api.com
ODDS_API_KEY=your_odds_api_key

# ── Local dev only (optional)
# If you run plain `vite dev` instead of `vercel dev`, point this at your local API server
# VITE_API_PROXY=http://localhost:3001

# Clerk auth (client-safe — VITE_ prefix is correct here)
VITE_CLERK_PUBLISHABLE_KEY = pk_live_your_key

# Clerk secret (server-side only — NO VITE_ prefix)
CLERK_SECRET_KEY           = sk_live_your_key

# Vercel KV (server-side only — NO VITE_ prefix)
KV_REST_API_URL            = https://your-kv.upstash.io
KV_REST_API_TOKEN          = your_token
